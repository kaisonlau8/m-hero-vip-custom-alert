	<true/>
	<key>KeepAlive</key>
	<dict>
		<key>SuccessfulExit</key>
		<false/>
	</dict>
	<key>ThrottleInterval</key>
	<integer>5</integer>
	<key>StandardOutPath</key>
	<string>/Users/i/Library/Logs/com.m-hero-vip-custom-alert.web.out.log</string>
	<key>StandardErrorPath</key>
	<string>/Users/i/Library/Logs/com.m-hero-vip-custom-alert.web.err.log</string>
